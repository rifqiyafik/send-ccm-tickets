LOG_LEVEL=info
# LOG_LEVEL pilihan: debug, info, warn, error, silent.
# LOG_COLOR=false untuk mematikan warna ANSI jika terminal tidak mendukung.
LOG_COLOR=true
# Optional untuk Docker Compose deploy. Isi dengan image registry di VM.
# Contoh: ghcr.io/username/send-ccm-ticket:latest
APP_IMAGE=send-ccm-ticket:latest
# BAILEYS_LOG_LEVEL pilihan: silent, fatal, error, warn, info, debug, trace.
# Biarkan silent agar log internal Baileys tidak memenuhi terminal.
BAILEYS_LOG_LEVEL=silent
# Optional. Pakai jika fetchLatestBaileysVersion memberi versi lama dan koneksi 408.
WA_WEB_VERSION=
# Fallback single-session auth dir. Multi-session memakai WA_SESSION_ROOT.
WA_AUTH_DIR=sessions/baileys
WA_SESSION_ROOT=sessions/whatsapp
WA_SESSION_REGISTRY_PATH=config/whatsapp_sessions.json
WA_AUTO_START=false
# Optional override path reference data. Kosongkan untuk memakai data bawaan image.
CCM_HANDLING_DATA_PATH=
NOP_SITE_DATA_PATH=

# Telegram command center.
# Buat bot dari BotFather, isi token di sini, lalu chat bot sekali.
# Jika TELEGRAM_ADMIN_CHAT_IDS kosong, bot akan membalas Chat ID kamu saat command dikirim.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_IDS=
TELEGRAM_POLL_TIMEOUT_SECONDS=30
TELEGRAM_ACCESS_CONFIG_PATH=config/telegram.json

# Optional. Isi jika command .groups/.private boleh dipakai nomor admin selain akun bot.
# JID di sini juga otomatis diizinkan memakai bot dari private chat.
# Format JID private: 628xxxxxxxxxx@s.whatsapp.net atau 109xxxxx@lid jika Baileys menampilkan LID.
OWNER_JIDS=
JID_SEARCH_LIMIT=50

# Anti-spam pacing untuk pesan eskalasi tiket.
# Default: 1 pesan tiap 5 detik, extra jeda 5 detik setiap 10 tiket per assignment.
WA_SEND_DELAY_MS=5000
WA_BATCH_SIZE=10
WA_BATCH_EXTRA_DELAY_MS=5000
SENT_TICKET_STORE_PATH=data/runtime/sent_tickets.json
SENT_TICKET_RETENTION_DAYS=7

# Optional fallback routing lama. Prefer pakai target_groups di config/whatsapp.json.
# Jika kosong dan target_groups tidak cocok, tiket dikirim balik ke chat pengirim file.
# Format: KEY:whatsapp_jid,KEY2:whatsapp_jid
# KEY bisa nama PIC, NSA, atau assignment_type seperti SQA/NOP.
# Contoh:
# WHATSAPP_GROUPS=HERMAN:120363000000000000@g.us,RIZLUL KHAIRI:120363111111111111@g.us,SQA:120363222222222222@g.us
WHATSAPP_GROUPS=
